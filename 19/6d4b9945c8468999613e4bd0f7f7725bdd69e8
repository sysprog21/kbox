            "content": "/* Kernel House orchestrator.\n *\n * Manages the penguin roster (resident Tux characters + guest pool),\n * drives the animation loop via requestAnimationFrame, and provides\n * the demo sequence for Milestone 1.\n */\n'use strict';\n\nvar KHouse = {\n  penguins: [],       /* all penguin instances */\n  guests: [],         /* guest penguin pool (subset of penguins) */\n  residents: {},      /* room id -> penguin instance */\n  crowdCount: 0,      /* overflow guest count for badge */\n  running: false,\n  lastTick: 0,\n  GUEST_POOL_SIZE: 8,\n\n  /* Room -> resident penguin config */\n  RESIDENT_CONFIG: {\n    gate:    { acc: 'hat',       facing: 0 },\n    vfs:     { acc: 'folder',    facing: 0 },\n    process: { acc: 'stopwatch', facing: 0 },\n    memory:  { acc: 'memblock',  facing: 0 },\n    network: { acc: 'envelope',  facing: 0 },\n    fdvault: { acc: null,        facing: 0 }\n  },\n\n  init: function() {\n    KPenguin.init();\n    this.createResidents();\n    this.createGuestPool();\n    this.bindDemo();\n    this.start();\n  },\n\n  createResidents: function() {\n    var ids = Object.keys(this.RESIDENT_CONFIG);\n    for (var i = 0; i < ids.length; i++) {\n      var roomId = ids[i];\n      var cfg = this.RESIDENT_CONFIG[roomId];\n      var center = this.roomCenter(roomId);\n      var p = KPenguin.create({\n        id: 'res-' + roomId,\n        x: center.x,\n        y: center.y,\n        facing: cfg.facing,\n        acc: cfg.acc,\n        room: roomId,\n        speed: 1.5\n      });\n      this.penguins.push(p);\n      this.residents[roomId] = p;\n    }\n  },\n\n  createGuestPool: function() {\n    for (var i = 0; i < this.GUEST_POOL_SIZE; i++) {\n      var center = this.roomCenter('attic');\n      var p = KPenguin.create({\n        id: 'guest-' + i,\n        x: center.x + (i - this.GUEST_POOL_SIZE / 2) * 20,\n        y: center.y,\n        isGuest: true,\n        visible: false,\n        room: 'attic',\n        speed: 2.5\n      });\n      this.penguins.push(p);\n      this.guests.push(p);\n    }\n  },\n\n  /* Get room center in canvas coords, offset downward for character feet */\n  roomCenter: function(roomId) {\n    var r = KScene.rooms[roomId];\n    if (!r) return { x: KScene.width / 2, y: KScene.height / 2 };\n    var cx = (r.x + r.w / 2) / 100 * KScene.width;\n    var cy = (r.y + r.h * 0.7) / 100 * KScene.height;\n    return { x: cx, y: cy };\n  },\n\n  /* Get an available guest penguin from the pool, or null */\n  acquireGuest: function() {\n    for (var i = 0; i < this.guests.length; i++) {\n      if (!this.guests[i].visible) {\n        this.guests[i].visible = true;\n        return this.guests[i];\n      }\n    }\n    this.crowdCount++;\n    return null;\n  },\n\n  releaseGuest: function(p) {\n    p.visible = false;\n    p.room = 'attic';\n    KPenguin.setState(p, 'idle');\n    if (this.crowdCount > 0) this.crowdCount--;\n  },\n\n  start: function() {\n    if (this.running) return;\n    this.running = true;\n    this.lastTick = performance.now();\n    this.loop(performance.now());\n  },\n\n  stop: function() {\n    this.running = false;\n  },\n\n  loop: function(now) {\n    if (!this.running) return;\n    requestAnimationFrame(this.loop.bind(this));\n\n    /* Tick at TICK_MS intervals */\n    if (now - this.lastTick >= KPenguin.TICK_MS) {\n      this.lastTick = now;\n      KPenguin.tick();\n\n      /* Update all penguins */\n      for (var i = 0; i < this.penguins.length; i++) {\n        KPenguin.update(this.penguins[i]);\n      }\n\n      KBubble.cleanup();\n    }\n\n    /* Render every frame for smooth walk interpolation */\n    this.render();\n  },\n\n  render: function() {\n    if (!KScene.ctx) return;\n    KScene.drawHouse();\n\n    /* Sort by Y for depth ordering */\n    var visible = [];\n    for (var i = 0; i < this.penguins.length; i++) {\n      if (this.penguins[i].visible) visible.push(this.penguins[i]);\n    }\n    visible.sort(function(a, b) { return a.y - b.y; });\n\n    for (var j = 0; j < visible.length; j++) {\n      KPenguin.draw(KScene.ctx, visible[j]);\n    }\n\n    /* Crowd badge */\n    if (this.crowdCount > 0) {\n      this.drawCrowdBadge();\n    }\n\n    /* Reposition bubbles */\n    KBubble.reposition(this.penguins);\n  },\n\n  drawCrowdBadge: function() {\n    var center = this.roomCenter('attic');\n    var ctx = KScene.ctx;\n    var text = '+' + this.crowdCount;\n    ctx.save();\n    ctx.font = 'bold 12px monospace';\n    ctx.fillStyle = '#58a6ff';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'bottom';\n    ctx.fillText(text, center.x + 60, center.y - 20);\n    ctx.restore();\n  },\n\n  /* --- Demo sequence (Milestone 1 exit criteria) --- */\n\n  bindDemo: function() {\n    var btn = document.getElementById('btn-demo');\n    if (btn) btn.addEventListener('click', this.runDemo.bind(this));\n  },\n\n  runDemo: function() {\n    var self = this;\n\n    /* Reset positions */\n    var ids = Object.keys(this.residents);\n    for (var i = 0; i < ids.length; i++) {\n      var c = this.roomCenter(ids[i]);\n      var p = this.residents[ids[i]];\n      p.x = c.x;\n      p.y = c.y;\n      KPenguin.setState(p, 'idle');\n    }\n\n    /* 1. Guest appears in attic */\n    var guest = this.acquireGuest();\n    if (!guest) return;\n    var atticCenter = this.roomCenter('attic');\n    guest.x = atticCenter.x - 40;\n    guest.y = atticCenter.y;\n    guest.visible = true;\n    KBubble.show(guest.id, 'openat', 2000);\n\n    /* 2. After 500ms, dispatcher walks toward gate center */\n    setTimeout(function() {\n      var gateCenter = self.roomCenter('gate');\n      KBubble.show('res-gate', 'openat → VFS', 2500);\n      KPenguin.setState(self.residents.gate, 'type');\n    }, 500);\n\n    /* 3. After 1.5s, guest walks to VFS */\n    setTimeout(function() {\n      var vfsCenter = self.roomCenter('vfs');\n      KPenguin.walkTo(guest, vfsCenter.x, vfsCenter.y, function() {\n        guest.room = 'vfs';\n        KPenguin.setState(self.residents.vfs, 'type');\n        KBubble.show('res-vfs', 'read, 15.2us', 2000);\n      });\n    }, 1500);\n\n    /* 4. After 3.5s, VFS Tux celebrates, guest returns */\n    setTimeout(function() {\n      KPenguin.setState(self.residents.vfs, 'celebrate');\n      KBubble.show(guest.id, 'OK', 1500);\n      setTimeout(function() {\n        KPenguin.walkTo(guest, atticCenter.x - 40, atticCenter.y, function() {\n          self.releaseGuest(guest);\n        });\n      }, 1000);\n    }, 3500);\n\n    /* 5. Concurrent: memory room activity */\n    setTimeout(function() {\n      KPenguin.setState(self.residents.memory, 'type');\n      KBubble.show('res-memory', 'mmap', 2000);\n      setTimeout(function() {\n        KPenguin.setState(self.residents.memory, 'celebrate');\n      }, 1500);\n    }, 2000);\n\n    /* 6. Error in network */\n    setTimeout(function() {\n      KPenguin.setState(self.residents.network, 'error');\n      KBubble.show('res-network', 'ENOSYS: accept4', 2000);\n    }, 3000);\n\n    /* 7. Context switch in process room */\n    setTimeout(function() {\n      KPenguin.setState(self.residents.process, 'type');\n      KBubble.show('res-process', 'context switch', 2000);\n    }, 1000);\n  }\n};\n",
