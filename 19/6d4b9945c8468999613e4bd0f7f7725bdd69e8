            "content": "/* SPDX-License-Identifier: MIT */\n\n#include \"../../src/x86-decode.h\"\n#include <stdio.h>\n#include <string.h>\n\nstatic int test_count;\nstatic int fail_count;\n\n#define EXPECT_LEN(desc, bytes, expected)                                      \\\n    do {                                                                       \\\n        unsigned char _buf[] = bytes;                                          \\\n        int _len = kbox_x86_insn_length(_buf, sizeof(_buf));                   \\\n        test_count++;                                                          \\\n        if (_len != (expected)) {                                              \\\n            fprintf(stderr, \"FAIL: %s: expected %d, got %d\\n\", desc,           \\\n                    (expected), _len);                                          \\\n            fail_count++;                                                      \\\n        }                                                                      \\\n    } while (0)\n\nvoid test_x86_decode(void)\n{\n    /* Basic single-byte instructions */\n    EXPECT_LEN(\"NOP\", {0x90}, 1);\n    EXPECT_LEN(\"RET\", {0xC3}, 1);\n    EXPECT_LEN(\"PUSH RAX\", {0x50}, 1);\n    EXPECT_LEN(\"POP RBX\", {0x5B}, 1);\n    EXPECT_LEN(\"HLT\", {0xF4}, 1);\n    EXPECT_LEN(\"CLD\", {0xFC}, 1);\n    EXPECT_LEN(\"LEAVE\", {0xC9}, 1);\n\n    /* REX prefix + opcode */\n    EXPECT_LEN(\"REX.W PUSH RAX\", {0x48, 0x50}, 2);\n\n    /* Two-byte syscall/sysenter */\n    EXPECT_LEN(\"SYSCALL (0F 05)\", {0x0F, 0x05}, 2);\n    EXPECT_LEN(\"SYSENTER (0F 34)\", {0x0F, 0x34}, 2);\n\n    /* Immediate instructions */\n    EXPECT_LEN(\"MOV EAX, imm32\", {0xB8, 0x01, 0x00, 0x00, 0x00}, 5);\n    EXPECT_LEN(\"MOV AL, imm8\", {0xB0, 0x42}, 2);\n    EXPECT_LEN(\"PUSH imm8\", {0x6A, 0x01}, 2);\n    EXPECT_LEN(\"PUSH imm32\", {0x68, 0x01, 0x02, 0x03, 0x04}, 5);\n\n    /* REX.W + MOV r64, imm64 (movabs) */\n    EXPECT_LEN(\"MOVABS RAX, imm64\",\n               {0x48, 0xB8, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08},\n               10);\n    EXPECT_LEN(\"MOVABS R11, imm64\",\n               {0x49, 0xBB, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08},\n               10);\n\n    /* ModR/M, register-direct */\n    EXPECT_LEN(\"ADD EAX, ECX (modrm reg)\", {0x01, 0xC8}, 2);\n    EXPECT_LEN(\"XOR RAX, RAX\", {0x48, 0x31, 0xC0}, 3);\n\n    /* ModR/M, memory indirect [RBP] with disp8 */\n    EXPECT_LEN(\"MOV [RBP-8], RAX\", {0x48, 0x89, 0x45, 0xF8}, 4);\n\n    /* ModR/M, memory [RSP+disp8] -- needs SIB */\n    EXPECT_LEN(\"MOV [RSP+0x10], RAX\", {0x48, 0x89, 0x44, 0x24, 0x10}, 5);\n\n    /* ModR/M, RIP-relative (mod=00, rm=5) */\n    EXPECT_LEN(\"LEA RAX, [RIP+disp32]\",\n               {0x48, 0x8D, 0x05, 0x00, 0x01, 0x02, 0x03}, 7);\n\n    /* ModR/M, SIB with disp32 (mod=00, rm=4, base=5) */\n    EXPECT_LEN(\"MOV EAX, [disp32+RSI*4]\",\n               {0x8B, 0x04, 0xB5, 0x00, 0x10, 0x20, 0x30}, 7);\n\n    /* Jcc rel8 */\n    EXPECT_LEN(\"JE rel8\", {0x74, 0x0A}, 2);\n    EXPECT_LEN(\"JNE rel8\", {0x75, 0x10}, 2);\n\n    /* Jcc rel32 (0F 8x) */\n    EXPECT_LEN(\"JE rel32\", {0x0F, 0x84, 0x00, 0x01, 0x00, 0x00}, 6);\n\n    /* CALL rel32 */\n    EXPECT_LEN(\"CALL rel32\", {0xE8, 0x00, 0x01, 0x00, 0x00}, 5);\n\n    /* JMP rel32 */\n    EXPECT_LEN(\"JMP rel32\", {0xE9, 0x00, 0x01, 0x00, 0x00}, 5);\n\n    /* JMP rel8 */\n    EXPECT_LEN(\"JMP rel8\", {0xEB, 0x10}, 2);\n\n    /* ALU imm: ADD EAX, imm32 */\n    EXPECT_LEN(\"ADD EAX, imm32\", {0x05, 0x01, 0x02, 0x03, 0x04}, 5);\n\n    /* Group 1 (83): ADD [RBP-4], imm8 (modrm + disp8 + imm8) */\n    EXPECT_LEN(\"ADD [RBP-4], imm8\", {0x83, 0x45, 0xFC, 0x01}, 4);\n\n    /* Group 1 (81): ADD [RBP-4], imm32 */\n    EXPECT_LEN(\"ADD [RBP-4], imm32\",\n               {0x81, 0x45, 0xFC, 0x01, 0x02, 0x03, 0x04}, 7);\n\n    /* ENTER iw,ib */\n    EXPECT_LEN(\"ENTER\", {0xC8, 0x00, 0x01, 0x00}, 4);\n\n    /* RET imm16 */\n    EXPECT_LEN(\"RET imm16\", {0xC2, 0x08, 0x00}, 3);\n\n    /* INT 