            "content": "/* Kernel House scene layout engine.\n *\n * Draws the \"kernel house\" cross-section on a <canvas>.  Each room is a\n * rectangular region with a flat-color background.  Room coordinates are\n * stored as percentages of the canvas so the layout scales with viewport.\n */\n'use strict';\n\nvar KScene = {\n  canvas: null,\n  ctx: null,\n  overlay: null,    /* DOM overlay for speech bubbles / panels */\n  strings: null,    /* loaded from strings.json */\n  width: 0,\n  height: 0,\n\n  /* Room definitions: id -> {x%, y%, w%, h%, color, label, active} */\n  rooms: {\n    attic:   { x: 0,  y: 0,  w: 100, h: 14, color: '#1a2233', label: 'User Space',    active: true  },\n    gate:    { x: 0,  y: 14, w: 100, h: 10, color: '#1f2a3a', label: 'Syscall Gate',   active: true  },\n    vfs:     { x: 0,  y: 24, w: 25,  h: 40, color: '#1a2840', label: 'VFS',            active: true  },\n    process: { x: 25, y: 24, w: 25,  h: 40, color: '#1a2540', label: 'Process Mgmt',   active: true  },\n    memory:  { x: 50, y: 24, w: 25,  h: 40, color: '#1a2040', label: 'Memory Mgmt',    active: true  },\n    network: { x: 75, y: 24, w: 25,  h: 40, color: '#1a1f40', label: 'Network',        active: true  },\n    basement:{ x: 0,  y: 64, w: 70,  h: 16, color: '#12151c', label: 'Block I/O',      active: false },\n    fdvault: { x: 70, y: 64, w: 30,  h: 16, color: '#181d28', label: 'FD Table',       active: true  }\n  },\n\n  /* Room glow intensities 0..1, driven by telemetry */\n  glow: {},\n\n  init: function(canvasId, overlayId) {\n    this.canvas = document.getElementById(canvasId);\n    if (!this.canvas) return;\n    this.ctx = this.canvas.getContext('2d');\n    this.overlay = document.getElementById(overlayId);\n\n    /* Disable smoothing for pixel art */\n    this.ctx.imageSmoothingEnabled = false;\n\n    /* Initialize glow map */\n    var ids = Object.keys(this.rooms);\n    for (var i = 0; i < ids.length; i++) {\n      this.glow[ids[i]] = 0;\n    }\n\n    this.resize();\n    window.addEventListener('resize', this.resize.bind(this));\n\n    /* Load strings */\n    this.loadStrings();\n  },\n\n  loadStrings: function() {\n    var self = this;\n    fetch('/js/strings.json')\n      .then(function(r) { return r.json(); })\n      .then(function(data) { self.strings = data; })\n      .catch(function() { self.strings = {}; });\n  },\n\n  str: function(path) {\n    if (!this.strings) return path;\n    var parts = path.split('.');\n    var obj = this.strings;\n    for (var i = 0; i < parts.length; i++) {\n      obj = obj && obj[parts[i]];\n    }\n    return obj || path;\n  },\n\n  resize: function() {\n    if (!this.canvas) return;\n    var container = this.canvas.parentElement;\n    var w = container.clientWidth;\n    var h = Math.max(400, Math.round(w * 0.625)); /* 8:5 aspect */\n    this.canvas.width = w;\n    this.canvas.height = h;\n    this.width = w;\n    this.height = h;\n    this.ctx.imageSmoothingEnabled = false;\n  },\n\n  /* Convert room-relative percentage coords to pixel coords */\n  roomRect: function(id) {\n    var r = this.rooms[id];\n    if (!r) return null;\n    return {\n      x: Math.round(r.x / 100 * this.width),\n      y: Math.round(r.y / 100 * this.height),\n      w: Math.round(r.w / 100 * this.width),\n      h: Math.round(r.h / 100 * this.height)\n    };\n  },\n\n  /* Get center point of a room in canvas pixels */\n  roomCenter: function(id) {\n    var rect = this.roomRect(id);\n    if (!rect) return { x: 0, y: 0 };\n    return { x: rect.x + rect.w / 2, y: rect.y + rect.h / 2 };\n  },\n\n  /* Draw the full house scene (rooms + borders + labels).\n   * Called every frame by the animation loop. */\n  drawHouse: function() {\n    var ctx = this.ctx;\n    if (!ctx) return;\n    var w = this.width, h = this.height;\n\n    /* Clear */\n    ctx.fillStyle = '#0d1117';\n    ctx.fillRect(0, 0, w, h);\n\n    /* Draw each room */\n    var ids = Object.keys(this.rooms);\n    for (var i = 0; i < ids.length; i++) {\n      var id = ids[i];\n      var room = this.rooms[id];\n      var rect = this.roomRect(id);\n\n      /* Base color */\n      ctx.fillStyle = room.color;\n      if (!room.active) ctx.globalAlpha = 0.4;\n      ctx.fillRect(rect.x, rect.y, rect.w, rect.h);\n\n      /* Glow overlay */\n      var glowVal = this.glow[id] || 0;\n      if (glowVal > 0 && room.active) {\n        ctx.fillStyle = 'rgba(88, 166, 255, ' + (glowVal * 0.15) + ')';\n        ctx.fillRect(rect.x, rect.y, rect.w, rect.h);\n      }\n\n      ctx.globalAlpha = 1;\n\n      /* Border */\n      ctx.strokeStyle = '#30363d';\n      ctx.lineWidth = 1;\n      ctx.strokeRect(rect.x + 0.5, rect.y + 0.5, rect.w - 1, rect.h - 1);\n\n      /* Label */\n      var label = room.label;\n      var fontSize = Math.max(10, Math.round(h * 0.022));\n      ctx.font = fontSize + 'px monospace';\n      ctx.fillStyle = room.active ? '#8b949e' : '#484f58';\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'top';\n      ctx.fillText(label, rect.x + rect.w / 2, rect.y + 4);\n\n      /* Inactive badge */\n      if (!room.active) {\n        ctx.font = (fontSize - 2) + 'px monospace';\n        ctx.fillStyle = '#484f58';\n        ctx.fillText('(no data)', rect.x + rect.w / 2, rect.y + 4 + fontSize + 2);\n      }\n    }\n\n    /* House outline */\n    ctx.strokeStyle = '#58a6ff';\n    ctx.lineWidth = 2;\n    /* Top of attic with roof peak */\n    var roofPeakX = w / 2;\n    ctx.beginPath();\n    ctx.moveTo(0, Math.round(h * 0.14));\n    ctx.lineTo(roofPeakX, 0);\n    ctx.lineTo(w, Math.round(h * 0.14));\n    ctx.stroke();\n\n    /* Bottom frame */\n    var bottomY = Math.round(h * 0.80);\n    ctx.strokeStyle = '#30363d';\n    ctx.lineWidth = 2;\n    ctx.beginPath();\n    ctx.moveTo(0, bottomY);\n    ctx.lineTo(w, bottomY);\n    ctx.stroke();\n  },\n\n  /* Hit-test: which room was clicked? Returns room id or null */\n  hitTest: function(canvasX, canvasY) {\n    var ids = Object.keys(this.rooms);\n    for (var i = 0; i < ids.length; i++) {\n      var rect = this.roomRect(ids[i]);\n      if (canvasX >= rect.x && canvasX < rect.x + rect.w &&\n          canvasY >= rect.y && canvasY < rect.y + rect.h) {\n        return ids[i];\n      }\n    }\n    return null;\n  }\n};\n",
