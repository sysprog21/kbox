            "content": "#!/usr/bin/env python3\n\"\"\"Generate pixel-art penguin sprite sheets for kbox kernel house visualization.\n\nOutputs:\n  web/art/penguin-base.png    -- 7x3 sprite sheet (112x96), base Tux character\n  web/art/penguin-guest.png   -- 7x3 sprite sheet, smaller/lighter guest variant\n  web/art/acc-hat.png         -- 7x1 accessory strip, sorting hat (Dispatcher)\n  web/art/acc-folder.png      -- 7x1 accessory strip, folder (File Tux)\n  web/art/acc-stopwatch.png   -- 7x1 accessory strip, stopwatch (Sched Tux)\n  web/art/acc-memblock.png    -- 7x1 accessory strip, memory block (Memory Tux)\n  web/art/acc-envelope.png    -- 7x1 accessory strip, envelope (Net Tux)\n\nFrame layout (7 cols): idle, walk1, walk2, walk3, type1, type2, error\nRow layout (3 rows):   down (front), up (back), left/right (side)\n\nEach frame: 16x32 pixels. Total sheet: 112x96.\nAccessory strips: 112x32 (one row, composited on top of base).\n\"\"\"\n\nimport struct\nimport zlib\nimport os\n\nFRAME_W, FRAME_H = 16, 32\nCOLS, ROWS = 7, 3\nSHEET_W, SHEET_H = FRAME_W * COLS, FRAME_H * ROWS\n\n# Colors (RGBA)\nBLACK = (0, 0, 0, 255)\nWHITE = (255, 255, 255, 255)\nORANGE = (255, 165, 0, 255)       # beak/feet\nBELLY = (230, 230, 240, 255)      # belly white\nBODY = (20, 20, 30, 255)          # dark body\nEYE_W = (255, 255, 255, 255)      # eye white\nEYE_P = (10, 10, 10, 255)         # pupil\nCLEAR = (0, 0, 0, 0)\n\n# Guest variant (lighter)\nG_BODY = (60, 70, 100, 255)\nG_BELLY = (200, 210, 230, 255)\n\n# Accessory colors\nHAT_RED = (200, 40, 40, 255)\nHAT_GOLD = (255, 200, 50, 255)\nFOLDER_BROWN = (180, 140, 80, 255)\nFOLDER_TAB = (200, 160, 90, 255)\nWATCH_GRAY = (160, 160, 170, 255)\nWATCH_FACE = (230, 230, 230, 255)\nMEM_GREEN = (60, 180, 100, 255)\nMEM_DARK = (40, 140, 70, 255)\nENV_CREAM = (240, 230, 200, 255)\nENV_EDGE = (200, 180, 140, 255)\n\n\ndef make_png(width, height, pixels):\n    \"\"\"Create a minimal PNG from RGBA pixel data.\"\"\"\n    def chunk(ctype, data):\n        c = ctype + data\n        crc = struct.pack('>I', zlib.crc32(c) & 0xFFFFFFFF)\n        return struct.pack('>I', len(data)) + c + crc\n\n    raw = b''\n    for y in range(height):\n        raw += b'\\x00'  # filter: none\n        for x in range(width):\n            r, g, b, a = pixels[y * width + x]\n            raw += struct.pack('BBBB', r, g, b, a)\n\n    sig = b'\\x89PNG\\r\\n\\x1a\\n'\n    ihdr = struct.pack('>IIBBBBB', width, height, 8, 6, 0, 0, 0)\n    return sig + chunk(b'IHDR', ihdr) + chunk(b'IDAT', zlib.compress(raw, 9)) + chunk(b'IEND', b'')\n\n\ndef new_sheet(w=SHEET_W, h=SHEET_H):\n    return [CLEAR] * (w * h)\n\n\ndef put(pixels, w, x, y, color):\n    if 0 <= x < w and 0 <= y:\n        h = len(pixels) // w\n        if y < h:\n            pixels[y * w + x] = color\n\n\ndef fill_rect(pixels, w, x0, y0, rw, rh, color):\n    for dy in range(rh):\n        for dx in range(rw):\n            put(pixels, w, x0 + dx, y0 + dy, color)\n\n\ndef draw_penguin_frame(pixels, w, fx, fy, facing, anim, body_c, belly_c):\n    \"\"\"Draw one penguin frame at frame coords (fx, fy) in sheet.\n\n    facing: 0=down(front), 1=up(back), 2=side(left)\n    anim: 0=idle, 1-3=walk, 4=type1, 5=type2, 6=error\n    \"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H\n\n    # Walk bob offset\n    bob = 0\n    if anim in (1, 3):\n        bob = -1\n    elif anim == 2:\n        bob = -2\n\n    # Error shake\n    shake = 0\n    if anim == 6:\n        shake = 1\n\n    ox += shake\n\n    # Body (main oval-ish shape)\n    # Head: rows 4-11, body: rows 12-24, feet: rows 25-28\n    head_top = oy + 4 + bob\n    body_top = oy + 12 + bob\n\n    if facing == 0:  # front\n        # Head\n        fill_rect(pixels, w, ox + 4, head_top, 8, 8, body_c)\n        # Eyes\n        put(pixels, w, ox + 5, head_top + 3, EYE_W)\n        put(pixels, w, ox + 6, head_top + 3, EYE_P)\n        put(pixels, w, ox + 9, head_top + 3, EYE_W)\n        put(pixels, w, ox + 10, head_top + 3, EYE_P)\n        # Beak\n        put(pixels, w, ox + 7, head_top + 5, ORANGE)\n        put(pixels, w, ox + 8, head_top + 5, ORANGE)\n        # Blink on type2\n        if anim == 5:\n            put(pixels, w, ox + 5, head_top + 3, body_c)\n            put(pixels, w, ox + 6, head_top + 3, body_c)\n            put(pixels, w, ox + 9, head_top + 3, body_c)\n            put(pixels, w, ox + 10, head_top + 3, body_c)\n        # Body\n        fill_rect(pixels, w, ox + 3, body_top, 10, 12, body_c)\n        # Belly\n        fill_rect(pixels, w, ox + 5, body_top + 2, 6, 8, belly_c)\n        # Wings\n        fill_rect(pixels, w, ox + 2, body_top + 1, 1, 8, body_c)\n        fill_rect(pixels, w, ox + 13, body_top + 1, 1, 8, body_c)\n        # Wing flap on walk\n        if anim in (1, 3):\n            put(pixels, w, ox + 1, body_top + 2, body_c)\n            put(pixels, w, ox + 14, body_top + 2, body_c)\n        # Type pose: wing forward\n        if anim in (4, 5):\n            fill_rect(pixels, w, ox + 13, body_top + 3, 2, 3, body_c)\n        # Feet\n        foot_y = oy + 25 + bob\n        if anim == 1:\n            fill_rect(pixels, w, ox + 4, foot_y, 3, 2, ORANGE)\n            fill_rect(pixels, w, ox + 9, foot_y + 1, 3, 2, ORANGE)\n        elif anim == 3:\n            fill_rect(pixels, w, ox + 4, foot_y + 1, 3, 2, ORANGE)\n            fill_rect(pixels, w, ox + 9, foot_y, 3, 2, ORANGE)\n        else:\n            fill_rect(pixels, w, ox + 4, foot_y, 3, 2, ORANGE)\n            fill_rect(pixels, w, ox + 9, foot_y, 3, 2, ORANGE)\n\n    elif facing == 1:  # back\n        # Head\n        fill_rect(pixels, w, ox + 4, head_top, 8, 8, body_c)\n        # Body\n        fill_rect(pixels, w, ox + 3, body_top, 10, 12, body_c)\n        # Wings\n        fill_rect(pixels, w, ox + 2, body_top + 1, 1, 8, body_c)\n        fill_rect(pixels, w, ox + 13, body_top + 1, 1, 8, body_c)\n        if anim in (1, 3):\n            put(pixels, w, ox + 1, body_top + 2, body_c)\n            put(pixels, w, ox + 14, body_top + 2, body_c)\n        # Feet\n        foot_y = oy + 25 + bob\n        fill_rect(pixels, w, ox + 4, foot_y, 3, 2, ORANGE)\n        fill_rect(pixels, w, ox + 9, foot_y, 3, 2, ORANGE)\n\n    elif facing == 2:  # side (facing left)\n        # Head\n        fill_rect(pixels, w, ox + 3, head_top, 8, 8, body_c)\n        # Eye\n        put(pixels, w, ox + 4, head_top + 3, EYE_W)\n        put(pixels, w, ox + 3, head_top + 3, EYE_P)\n        if anim == 5:\n            put(pixels, w, ox + 4, head_top + 3, body_c)\n            put(pixels, w, ox + 3, head_top + 3, body_c)\n        # Beak\n        put(pixels, w, ox + 2, head_top + 5, ORANGE)\n        put(pixels, w, ox + 3, head_top + 5, ORANGE)\n        # Body\n        fill_rect(pixels, w, ox + 4, body_top, 8, 12, body_c)\n        # Belly\n        fill_rect(pixels, w, ox + 4, body_top + 2, 4, 8, belly_c)\n        # Wing (back side)\n        fill_rect(pixels, w, ox + 11, body_top + 1, 2, 8, body_c)\n        if anim in (4, 5):\n            fill_rect(pixels, w, ox + 2, body_top + 5, 2, 3, body_c)\n        # Feet\n        foot_y = oy + 25 + bob\n        if anim == 1:\n            fill_rect(pixels, w, ox + 4, foot_y, 3, 2, ORANGE)\n            fill_rect(pixels, w, ox + 7, foot_y + 1, 3, 2, ORANGE)\n        elif anim == 3:\n            fill_rect(pixels, w, ox + 4, foot_y + 1, 3, 2, ORANGE)\n            fill_rect(pixels, w, ox + 7, foot_y, 3, 2, ORANGE)\n        else:\n            fill_rect(pixels, w, ox + 5, foot_y, 3, 2, ORANGE)\n            fill_rect(pixels, w, ox + 8, foot_y, 3, 2, ORANGE)\n\n\ndef draw_acc_hat(pixels, w, fx, fy):\n    \"\"\"Sorting hat accessory at frame position.\"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H\n    # Pointed hat on top of head\n    top = oy + 1\n    fill_rect(pixels, w, ox + 5, top + 2, 6, 2, HAT_RED)\n    fill_rect(pixels, w, ox + 6, top + 1, 4, 1, HAT_RED)\n    fill_rect(pixels, w, ox + 7, top, 2, 1, HAT_RED)\n    # Gold band\n    fill_rect(pixels, w, ox + 4, top + 3, 8, 1, HAT_GOLD)\n\n\ndef draw_acc_folder(pixels, w, fx, fy):\n    \"\"\"Folder accessory held in wing area.\"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H + 16\n    fill_rect(pixels, w, ox + 12, oy, 4, 6, FOLDER_BROWN)\n    fill_rect(pixels, w, ox + 12, oy, 2, 1, FOLDER_TAB)\n\n\ndef draw_acc_stopwatch(pixels, w, fx, fy):\n    \"\"\"Stopwatch accessory.\"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H + 15\n    fill_rect(pixels, w, ox + 12, oy, 3, 3, WATCH_GRAY)\n    put(pixels, w, ox + 13, oy + 1, WATCH_FACE)\n    put(pixels, w, ox + 13, oy - 1, WATCH_GRAY)\n\n\ndef draw_acc_memblock(pixels, w, fx, fy):\n    \"\"\"Memory block accessory.\"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H + 14\n    fill_rect(pixels, w, ox + 12, oy, 3, 4, MEM_GREEN)\n    fill_rect(pixels, w, ox + 12, oy, 3, 1, MEM_DARK)\n\n\ndef draw_acc_envelope(pixels, w, fx, fy):\n    \"\"\"Envelope accessory.\"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H + 16\n    fill_rect(pixels, w, ox + 12, oy, 4, 3, ENV_CREAM)\n    # Flap triangle\n    put(pixels, w, ox + 13, oy, ENV_EDGE)\n    put(pixels, w, ox + 14, oy, ENV_EDGE)\n    fill_rect(pixels, w, ox + 12, oy, 4, 1, ENV_EDGE)\n\n\ndef generate_penguin_sheet(body_c, belly_c):\n    pixels = new_sheet()\n    for row in range(ROWS):\n        for col in range(COLS):\n            draw_penguin_frame(pixels, SHEET_W, col, row, row, col, body_c, belly_c)\n    return pixels\n\n\ndef generate_acc_sheet(draw_fn):\n    w = FRAME_W * COLS\n    h = FRAME_H  # single row\n    pixels = [CLEAR] * (w * h)\n    for col in range(COLS):\n        draw_fn(pixels, w, col, 0)\n    return pixels, w, h\n\n\ndef main():\n    script_dir = os.path.dirname(os.path.abspath(__file__))\n    art_dir = os.path.join(os.path.dirname(script_dir), 'web', 'art')\n    os.makedirs(art_dir, exist_ok=True)\n\n    # Base penguin\n    base = generate_penguin_sheet(BODY, BELLY)\n    with open(os.path.join(art_dir, 'penguin-base.png'), 'wb') as f:\n        f.write(make_png(SHEET_W, SHEET_H, base))\n\n    # Guest variant (lighter, smaller feel via color)\n    guest = generate_penguin_sheet(G_BODY, G_BELLY)\n    with open(os.path.join(art_dir, 'penguin-guest.png'), 'wb') as f:\n        f.write(make_png(SHEET_W, SHEET_H, guest))\n\n    # Accessories\n    accs = [\n        ('acc-hat.png', draw_acc_hat),\n        ('acc-folder.png', draw_acc_folder),\n        ('acc-stopwatch.png', draw_acc_stopwatch),\n        ('acc-memblock.png', draw_acc_memblock),\n        ('acc-envelope.png', draw_acc_envelope),\n    ]\n    for name, fn in accs:\n        pixels, w, h = generate_acc_sheet(fn)\n        with open(os.path.join(art_dir, name), 'wb') as f:\n            f.write(make_png(w, h, pixels))\n\n    print('Generated sprites in', art_dir)\n\n\nif __name__ == '__main__':\n    main()\n",
