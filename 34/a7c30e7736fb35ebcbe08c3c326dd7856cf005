            "content": "/* SPDX-License-Identifier: MIT */\n\n#include \"../../src/x86-decode.h\"\n#include <stdio.h>\n#include <string.h>\n\nstatic int test_count;\nstatic int fail_count;\n\n#define EXPECT_LEN(desc, bytes, expected)                                      \\\n    do {                                                                       \\\n        unsigned char _buf[] = bytes;                                          \\\n        int _len = kbox_x86_insn_length(_buf, sizeof(_buf));                   \\\n        test_count++;                                                          \\\n        if (_len != (expected)) {                                              \\\n            fprintf(stderr, \"FAIL: %s: expected %d, got %d\\n\", desc,           \\\n                    (expected), _len);                                          \\\n            fail_count++;                                                      \\\n        }                                                                      \\\n    } while (0)\n\nvoid test_x86_decode(void)\n{\n    /* Basic single-byte instructions */\n    EXPECT_LEN(\"NOP\", {0x90}, 1);\n    EXPECT_LEN(\"RET\", {0xC3}, 1);\n    EXPECT_LEN(\"PUSH RAX\", {0x50}, 1);\n    EXPECT_LEN(\"POP RBX\", {0x5B}, 1);\n    EXPECT_LEN(\"HLT\", {0xF4}, 1);\n    EXPECT_LEN(\"CLD\", {0xFC}, 1);\n    EXPECT_LEN(\"LEAVE\", {0xC9}, 1);\n\n    /* REX prefix + opcode */\n    EXPECT_LEN(\"REX.W PUSH RAX\", {0x48, 0x50}, 2);\n\n    /* Two-byte syscall/sysenter */\n    EXPECT_LEN(\"SYSCALL (0F 05)\", {0x0F, 0x05}, 2);\n    EXPECT_LEN(\"SYSENTER (0F 34)\", {0x0F, 0x34}, 2);\n\n    /* Immediate instructions */\n    EXPECT_LEN(\"MOV EAX, imm32\", {0xB8, 0x01, 0x00, 0x00, 0x00}, 5);\n    EXPECT_LEN(\"MOV AL, imm8\", {0xB0, 0x42}, 2);\n    EXPECT_LEN(\"PUSH imm8\", {0x6A, 0x01}, 2);\n    EXPECT_LEN(\"PUSH imm32\", {0x68, 0x01, 0x02, 0x03, 0x04}, 5);\n\n    /* REX.W + MOV r64, imm64 (movabs) */\n    EXPECT_LEN(\"MOVABS RAX, imm64\",\n              