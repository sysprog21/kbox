imm8 */\n    EXPECT_LEN(\"INT 0x80\", {0xCD, 0x80}, 2);\n\n    /* CMOVcc (0F 4x) with ModR/M */\n    EXPECT_LEN(\"CMOVE RAX, RCX\", {0x48, 0x0F, 0x44, 0xC1}, 4);\n\n    /* SETcc (0F 9x) with ModR/M */\n    EXPECT_LEN(\"SETE AL\", {0x0F, 0x94, 0xC0}, 3);\n\n    /* TEST r/m8, imm8 (F6 /0) -- Group 3 special case */\n    EXPECT_LEN(\"TEST [RBP-1], imm8\", {0xF6, 0x45, 0xFF, 0x01}, 4);\n\n    /* TEST r/m32, imm32 (F7 /0) -- Group 3 special case */\n    EXPECT_LEN(\"TEST EAX, imm32\", {0xF7, 0xC0, 0x01, 0x02, 0x03, 0x04}, 6);\n\n    /* NOT r/m32 (F7 /2) -- Group 3, no immediate */\n    EXPECT_LEN(\"NOT EAX\", {0xF7, 0xD0}, 2);\n\n    /* NEG r/m64 (REX.W F7 /3) */\n    EXPECT_LEN(\"NEG RAX\", {0x48, 0xF7, 0xD8}, 3);\n\n    /* CALL r/m64 (FF /2) */\n    EXPECT_LEN(\"CALL RAX\", {0xFF, 0xD0}, 2);\n    EXPECT_LEN(\"CALL [RBP-8]\", {0xFF, 0x55, 0xF8}, 3);\n\n    /* JMP r/m64 (FF /4) */\n    EXPECT_LEN(\"JMP *%r10\", {0x41, 0xFF, 0xE2}, 3);\n    EXPECT_LEN(\"JMP *%r11\", {0x41, 0xFF, 0xE3}, 3);\n\n    /* LOCK prefix */\n    EXPECT_LEN(\"LOCK XCHG\", {0xF0, 0x87, 0x03}, 3);\n\n    /* REP MOVSB */\n    EXPECT_LEN(\"REP MOVSB\", {0xF3, 0xA4}, 2);\n\n    /* CPUID (0F A2) */\n    EXPECT_LEN(\"CPUID\", {0x0F, 0xA2}, 2);\n\n    /* RDTSC (0F 31) */\n    EXPECT_LEN(\"RDTSC\", {0x0F, 0x31}, 2);\n\n    /* UD2 (0F 0B) */\n    EXPECT_LEN(\"UD2\", {0x0F, 0x0B}, 2);\n\n    /* 66h prefix: ADD AX, imm16 */\n    EXPECT_LEN(\"ADD AX, imm16\", {0x66, 0x05, 0x01, 0x02}, 4);\n\n    /* MOVZX (0F B6) */\n    EXPECT_LEN(\"MOVZX EAX, BYTE [RBP-1]\", {0x0F, 0xB6, 0x45, 0xFF}, 4);\n\n    /* IMUL r, r/m, imm8 */\n    EXPECT_LEN(\"IMUL EAX, ECX, 5\", {0x6B, 0xC1, 0x05}, 3);\n\n    /* IMUL r, r/m, imm32 */\n    EXPECT_LEN(\"IMUL EAX, ECX, imm32\",\n               {0x69, 0xC1, 0x01, 0x02, 0x03, 0x04}, 6);\n\n    /* Multi-byte NOP (0F 1F /0) with modrm */\n    EXPECT_LEN(\"NOP DWORD [RAX]\", {0x0F, 0x1F, 0x00}, 3);\n    EXPECT_LEN(\"NOP DWORD [RAX+disp8]\", {0x0F, 0x1F, 0x40, 0x00}, 4);\n    EXPECT_LEN(\"66 NOP DWORD [RAX+RAX+0]\",\n               {0x66, 0x0F, 0x1F, 0x44, 0x00, 0x00}, 6);\n\n    /* SSE: MOVAPS xmm, xmm (0F 28) */\n    EXPECT_LEN(\"MOVAPS XMM0, XMM1\", {0x0F, 0x28, 0xC1}, 3);\n\n    /* SHUFPS (0F C6): ModR/M + imm8 */\n    EXPECT_LEN(\"SHUFPS XMM0, XMM1, 0\",\n               {0x0F, 0xC6, 0xC1, 0x00}, 4);\n\n    /* Truncated input */\n    {\n        unsigned char buf[] = {0x0F}; /* incomplete two-byte opcode */\n        test_count++;\n        if (kbox_x86_insn_length(buf, 1) != 0) {\n            fprintf(stderr, \"FAIL: truncated 0F should return 0\\n\");\n            fail_count++;\n        }\n    }\n\n    /* NULL input */\n    test_count++;\n    if (kbox_x86_insn_length(NULL, 10) != 0) {\n        fprintf(stderr, \"FAIL: NULL should return 0\\n\");\n        fail_count++;\n    }\n\n    /* Zero length */\n    {\n        unsigned char buf[] = {0x90};\n        test_count++;\n        if (kbox_x86_insn_length(buf, 0) != 0) {\n            fprintf(stderr, \"FAIL: zero length should return 0\\n\");\n            fail_count++;\n        }\n    }\n\n    /* Critical: 0F 05 appearing as immediate data inside a longer instruction\n     * must NOT be decoded as a 2-byte syscall. Verify by checking that the\n     * instruction containing the embedded bytes is longer than 2.\n     */\n\n    /* MOV EAX, 0x0000050F -- the bytes 0F 05 appear at offset 1-2 */\n    EXPECT_LEN(\"MOV EAX, 0x050F (contains 0F 05 as imm)\",\n               {0xB8, 0x0F, 0x05, 0x00, 0x00}, 5);\n\n    /* CMP BYTE [RBP-1], 0x0F -- 80 7D FF 0F */\n    EXPECT_LEN(\"CMP byte [rbp-1], 0x0F\", {0x80, 0x7D, 0xFF, 0x0F}, 4);\n\n    /* MOV [RSP+0x0F], 0x05 -- C6 44 24 0F 05 */\n    EXPECT_LEN(\"MOV byte [rsp+0x0f], 5\",\n               {0xC6, 0x44, 0x24, 0x0F, 0x05}, 5);\n\n    /* BT r/m, imm8: 0F BA /4 ib -- 0F BA E0 34 (BT EAX, 0x34)\n     * The byte 34 could look like the second byte of sysenter (0F 34).\n     */\n    EXPECT_LEN(\"BT EAX, 0x34 (contains 34 after 0F BA)\",\n               {0x0F, 0xBA, 0xE0, 0x34}, 4);\n\n    /* 3-byte escape 0F 38: PSHUFB (66 0F 38 00 /r) */\n    EXPECT_LEN(\"PSHUFB XMM0, XMM1\",\n               {0x66, 0x0F, 0x38, 0x00, 0xC1}, 5);\n\n    /* 3-byte escape 0F 3A: PALIGNR (66 0F 3A 0F /r ib) */\n    EXPECT_LEN(\"PALIGNR XMM0, XMM1, 4\",\n               {0x66, 0x0F, 0x3A, 0x0F, 0xC1, 0x04}, 6);\n\n    /* MOV moffs: A1 + 8-byte address (64-bit mode default) */\n    EXPECT_LEN(\"MOV EAX, moffs64\",\n               {0xA1, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08}, 9);\n\n    /* MOV moffs with 67h: A1 + 4-byte address */\n    EXPECT_LEN(\"MOV EAX, moffs32 (67h)\",\n               {0x67, 0xA1, 0x01, 0x02, 0x03, 0x04}, 6);\n\n    /* BSWAP (0F C8+rd) */\n    EXPECT_LEN(\"BSWAP EAX\", {0x0F, 0xC8}, 2);\n    EXPECT_LEN(\"BSWAP RAX\", {0x48, 0x0F, 0xC8}, 3);\n\n    /* XADD (0F C1) */\n    EXPECT_LEN(\"XADD [RAX], ECX\", {0x0F, 0xC1, 0x08}, 3);\n\n    /* CMPXCHG (0F B1) */\n    EXPECT_LEN(\"CMPXCHG [RAX], ECX\", {0x0F, 0xB1, 0x08}, 3);\n}\n",
