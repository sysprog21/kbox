            "content": "#!/usr/bin/env python3\n\"\"\"Merge standalone /* openers with the first line of comment text.\n\nTransforms:\n    /*\n     * First line of text ...\n     * More text.\n     */\nInto:\n    /* First line of text ...\n     * More text.\n     */\n\nReflows the first line if merging would exceed 80 columns.\n\"\"\"\n\nimport re\nimport sys\nimport textwrap\n\n\ndef fix_file(path):\n    with open(path) as f:\n        lines = f.readlines()\n\n    out = []\n    i = 0\n    changed = False\n    while i < len(lines):\n        line = lines[i]\n        # Match a line that is just /* (with optional leading whitespace)\n        m = re.match(r'^(\\s*)/\\*\\s*$', line)\n        if m and i + 1 < len(lines):\n            indent = m.group(1)\n            next_line = lines[i + 1]\n            # Next line should be \" * text\" with matching indent\n            m2 = re.match(\n                r'^' + re.escape(indent) + r' \\* (.+)$', next_line\n            )\n            if m2:\n                first_text = m2.group(1)\n                merged = indent + '/* ' + first_text\n                if len(merged) <= 80:\n                    # Simple merge: fits on one line\n                    out.append(merged + '\\n')\n                    i += 2\n                    changed = True\n                    continue\n                else:\n                    # Need to reflow: split words to fit 80 chars\n                    prefix = indent + '/* '\n                    avail = 80 - len(prefix)\n                    words = first_text.split()\n                    first_part = []\n                    remaining = []\n                    cur_len = 0\n                    for wi, w in enumerate(words):\n                        add_len = len(w) + (1 if first_part else 0)\n                        if cur_len + add_len <= avail:\n                            first_part.append(w)\n                            cur_len += add_len\n                        else:\n                            remaining = words[wi:]\n                            break\n                    if first_part:\n                        out.append(prefix + ' '.join(first_part) + '\\n')\n                        if remaining:\n                            cont_prefix = indent + ' * '\n                            out.append(\n                                cont_prefix + ' '.join(remaining) + '\\n'\n                            )\n                        i += 2\n                        changed = True\n                        continue\n            # If next line is blank \" *\" (paragraph break), also merge\n            m3 = re.match(\n                r'^' + re.escape(indent) + r' \\*\\s*$', next_line\n            )\n            if m3:\n                # standalone /* followed by blank continuation; skip this\n                # pattern as it represents a header with blank line after\n                # the opening. We still merge /* with the blank to keep\n                # the /* from being alone, but we need the first text line.\n                # Actually, for this case just keep as-is since there's no\n                # text to merge with on the immediate next line.\n                pass\n\n        out.append(line)\n        i += 1\n\n    if changed:\n        with open(path, 'w') as f:\n            f.writelines(out)\n        return True\n    return False\n\n\nif __name__ == '__main__':\n    import glob\n    import os\n\n    base = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))\n    patterns = [\n        'src/**/*.c', 'src/**/*.h',\n        'include/**/*.h',\n        'tests/**/*.c', 'tests/**/*.h',\n    ]\n    files = []\n    for pat in patterns:\n        files.extend(\n            glob.glob(os.path.join(base, pat), recursive=True)\n        )\n\n    total = 0\n    for f in sorted(set(files)):\n        if fix_file(f):\n            print(f'Fixed: {f}')\n            total += 1\n    print(f'\\n{total} files modified.')\n",
