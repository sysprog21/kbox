            "old_string": "/* Minimal deny-only BPF filter for SUD-based dispatch.\n *\n * When Syscall User Dispatch (SUD) handles the interception, the BPF filter\n * only needs to block the deny list.  No IP-range gating, no TRAP action --\n * SUD fires before seccomp in the kernel entry path, so normal guest\n * syscalls never reach BPF.  The deny list catches the case where a guest\n * directly issues a dangerous syscall that SUD dispatches to the handler\n * and the handler re-executes via host_syscall (which bypasses SUD because\n * the selector is toggled to ALLOW during dispatch).\n */\n/* Syscall User Dispatch (SUD) -- Linux 5.11+.\n *\n * SUD dispatches syscalls from outside a designated IP range to SIGSYS\n * without BPF evaluation.  Combined with a deny-only BPF filter, this\n * provides near-zero-cost interception with full deny-list enforcement.\n *\n * The selector byte lives in thread-local storage.  Set it to\n * SYSCALL_DISPATCH_FILTER_BLOCK (0x01) for guest execution and\n * SYSCALL_DISPATCH_FILTER_ALLOW (0x00) when the handler issues host\n * syscalls.  The handler already toggles via the host_syscall trampoline\n * (which lives in the allowed dispatcher range).\n */\n#ifndef PR_SET_SYSCALL_USER_DISPATCH\n#define PR_SET_SYSCALL_USER_DISPATCH 59\n#endif\n#ifndef PR_SYS_DISPATCH_ON\n#define PR_SYS_DISPATCH_ON 1\n#endif\n#ifndef SYSCALL_DISPATCH_FILTER_BLOCK\n#define SYSCALL_DISPATCH_FILTER_BLOCK 1\n#endif\n\nstatic __thread char sud_selector = 1; /* BLOCK by default for guest */\n\nint kbox_install_sud(uintptr_t guest_start, uintptr_t guest_end)\n{\n    uintptr_t len;\n\n    if (guest_end <= guest_start)\n        return -1;\n    len = guest_end - guest_start;\n\n    /* SUD requires PR_SET_NO_NEW_PRIVS (already set by the caller). */\n    if (prctl(PR_SET_SYSCALL_USER_DISPATCH, PR_SYS_DISPATCH_ON,\n              (unsigned long) guest_start, (unsigned long) len,\n              &sud_selector) != 0)\n        return -1;\n\n    return 0;\n}\n\nint kbox_install_seccomp_deny_only(const struct kbox_host_nrs *h)\n{\n    struct kbox_sock_filter filter[MAX_PROG_LEN];\n    struct kbox_sock_fprog prog;\n    int idx = 0;\n    int i;\n\n    (void) h;\n\n    /* Load arch, validate. */\n    filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_STMT(\n        KBOX_BPF_LD | KBOX_BPF_W | KBOX_BPF_ABS, KBOX_SECCOMP_DATA_ARCH_OFFSET);\n    filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_JUMP(\n        KBOX_BPF_JMP | KBOX_BPF_JEQ | KBOX_BPF_K, KBOX_AUDIT_ARCH_CURRENT, 1,\n        0);\n    filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_STMT(\n        KBOX_BPF_RET | KBOX_BPF_K, KBOX_SECCOMP_RET_KILL_PROCESS);\n\n    /* Load syscall number. */\n    filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_STMT(\n        KBOX_BPF_LD | KBOX_BPF_W | KBOX_BPF_ABS, KBOX_SECCOMP_DATA_NR_OFFSET);\n\n    /* Deny list: return EPERM for each blocked syscall. */\n    for (i = 0; i < DENY_COUNT; i++) {\n        if (deny_nrs[i] < 0)\n            continue;\n        filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_JUMP(\n            KBOX_BPF_JMP | KBOX_BPF_JEQ | KBOX_BPF_K,\n            (unsigned int) deny_nrs[i], 0, 1);\n        filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_STMT(\n            KBOX_BPF_RET | KBOX_BPF_K, KBOX_SECCOMP_RET_ERRNO(1));\n    }\n\n    /* Default: allow everything else. */\n    filter[idx++] = (struct kbox_sock_filter) KBOX_BPF_STMT(\n        KBOX_BPF_RET | KBOX_BPF_K, KBOX_SECCOMP_RET_ALLOW);\n\n    if (idx > MAX_PROG_LEN)\n        return -1;\n\n    prog.len = (unsigned short) idx;\n    prog.filter = filter;\n\n    /* PR_SET_NO_NEW_PRIVS already set by the caller. */\n    return syscall(__NR_seccomp, KBOX_SECCOMP_SET_MODE_FILTER, 0, &prog) < 0\n               ? -1\n               : 0;\n}",
