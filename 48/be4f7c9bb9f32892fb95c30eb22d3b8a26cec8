            "content": "/* Penguin sprite animation engine.\n *\n * Renders pixel-art penguins on KScene's canvas.  Each penguin has a\n * state machine (idle/walk/type/celebrate/error), position, facing\n * direction, and optional accessory overlay.\n *\n * Sprite sheet layout: 7 columns x 3 rows, each frame 16x32 px.\n *   Columns: 0=idle, 1-3=walk cycle, 4=type1, 5=type2, 6=error\n *   Rows:    0=down(front), 1=up(back), 2=side(left)\n *\n * Side-facing sprites face left; mirror via scaleX(-1) for right.\n */\n'use strict';\n\nvar KPenguin = {\n  FRAME_W: 16,\n  FRAME_H: 32,\n  COLS: 7,\n  SCALE: 2.5,       /* render scale for pixel art */\n  TICK_MS: 120,     /* animation frame interval */\n\n  /* Sprite images (loaded in init) */\n  imgBase: null,\n  imgGuest: null,\n  accImages: {},     /* 'hat','folder','stopwatch','memblock','envelope' -> Image */\n\n  /* Animation sequences: state -> frame index array */\n  ANIMS: {\n    idle:      [0],\n    walk:      [1, 2, 3, 2],\n    type:      [4, 5],\n    celebrate: [4, 5],\n    error:     [6, 4]\n  },\n\n  /* State -> row (facing) is separate; default facing per-character */\n  /* State durations (ticks before returning to idle, 0 = loop forever) */\n  DURATIONS: {\n    idle: 0,\n    walk: 0,        /* walk ends when destination reached */\n    type: 8,        /* ~1s */\n    celebrate: 6,\n    error: 8\n  },\n\n  loaded: false,\n  clock: 0,         /* global tick counter */\n\n  init: function() {\n    var self = this;\n    var pending = 7;\n    var done = function() { if (--pending === 0) self.loaded = true; };\n\n    this.imgBase = new Image();\n    this.imgBase.onload = done;\n    this.imgBase.src = '/art/penguin-base.png';\n\n    this.imgGuest = new Image();\n    this.imgGuest.onload = done;\n    this.imgGuest.src = '/art/penguin-guest.png';\n\n    var accNames = ['hat', 'folder', 'stopwatch', 'memblock', 'envelope'];\n    for (var i = 0; i < accNames.length; i++) {\n      var img = new Image();\n      img.onload = done;\n      img.src = '/art/acc-' + accNames[i] + '.png';\n      this.accImages[accNames[i]] = img;\n    }\n  },\n\n  tick: function() {\n    this.clock++;\n  },\n\n  /* Create a penguin instance */\n  create: function(opts) {\n    return {\n      id: opts.id || '',\n      x: opts.x || 0,          /* canvas pixel position */\n      y: opts.y || 0,\n      targetX: opts.x || 0,    /* movement destination */\n      targetY: opts.y || 0,\n      state: 'idle',\n      facing: opts.facing || 0, /* 0=down, 1=up, 2=side */\n      flipX: false,             /* mirror for right-facing */\n      frameIdx: 0,              /* index into ANIMS[state] */\n      stateTimer: 0,            /* ticks remaining in current state */\n      acc: opts.acc || null,    /* accessory name or null */\n      isGuest: opts.isGuest || false,\n      visible: opts.visible !== undefined ? opts.visible : true,\n      room: opts.room || 'gate',\n      speed: opts.speed || 2,   /* pixels per frame for walk */\n      onArrive: null            /* callback when walk completes */\n    };\n  },\n\n  /* Transition penguin to a new state */\n  setState: function(p, state) {\n    if (p.state === state) return;\n    p.state = state;\n    p.frameIdx = 0;\n    p.stateTimer = this.DURATIONS[state] || 0;\n  },\n\n  /* Start walking toward (tx, ty).  Callback fires on arrival. */\n  walkTo: function(p, tx, ty, onArrive) {\n    p.targetX = tx;\n    p.targetY = ty;\n    p.onArrive = onArrive || null;\n    this.setState(p, 'walk');\n\n    /* Determine facing from direction */\n    var dx = tx - p.x;\n    var dy = ty - p.y;\n    if (Math.abs(dx) > Math.abs(dy)) {\n      p.facing = 2; /* side */\n      p.flipX = dx > 0;\n    } else if (dy < 0) {\n      p.facing = 1; /* up/back */\n    } else {\n      p.facing = 0; /* down/front */\n    }\n  },\n\n  /* Update one penguin for the current tick */\n  update: function(p) {\n    if (!p.visible) return;\n\n    /* Walk movement */\n    if (p.state === 'walk') {\n      var dx = p.targetX - p.x;\n      var dy = p.targetY - p.y;\n      var dist = Math.sqrt(dx * dx + dy * dy);\n      if (dist < p.speed) {\n        p.x = p.targetX;\n        p.y = p.targetY;\n        this.setState(p, 'idle');\n        if (p.onArrive) {\n          var cb = p.onArrive;\n          p.onArrive = null;\n          cb(p);\n        }\n      } else {\n        p.x += (dx / dist) * p.speed;\n        p.y += (dy / dist) * p.speed;\n      }\n    }\n\n    /* State timer countdown */\n    if (p.stateTimer > 0) {\n      p.stateTimer--;\n      if (p.stateTimer <= 0 && p.state !== 'walk') {\n        this.setState(p, 'idle');\n      }\n    }\n\n    /* Advance frame */\n    var anim = this.ANIMS[p.state] || this.ANIMS.idle;\n    if (this.clock % 2 === 0) { /* advance every other tick for smoother look */\n      p.frameIdx = (p.frameIdx + 1) % anim.length;\n    }\n  },\n\n  /* Draw one penguin on the canvas context */\n  draw: function(ctx, p) {\n    if (!p.visible || !this.loaded) return;\n\n    var anim = this.ANIMS[p.state] || this.ANIMS.idle;\n    var col = anim[p.frameIdx % anim.length];\n    var row = p.facing;\n    var img = p.isGuest ? this.imgGuest : this.imgBase;\n\n    var sw = this.FRAME_W;\n    var sh = this.FRAME_H;\n    var sx = col * sw;\n    var sy = row * sh;\n    var dw = sw * this.SCALE;\n    var dh = sh * this.SCALE;\n    var dx = Math.round(p.x - dw / 2);\n    var dy = Math.round(p.y - dh);\n\n    /* Bob offset for walk */\n    var bob = 0;\n    if (p.state === 'walk') {\n      bob = Math.sin(this.clock * 0.5) * 2;\n    } else if (p.state === 'celebrate') {\n      bob = -Math.abs(Math.sin(this.clock * 0.4)) * 4;\n    }\n\n    /* Shake offset for error */\n    var shake = 0;\n    if (p.state === 'error') {\n      shake = (this.clock % 2 === 0) ? 2 : -2;\n    }\n\n    /* Shadow */\n    ctx.save();\n    ctx.globalAlpha = 0.3;\n    ctx.fillStyle = '#000';\n    ctx.beginPath();\n    ctx.ellipse(p.x + shake, p.y + 2, dw * 0.35, dh * 0.08, 0, 0, Math.PI * 2);\n    ctx.fill();\n    ctx.restore();\n\n    /* Sprite */\n    ctx.save();\n    if (p.flipX) {\n      ctx.translate(p.x + shake, dy + bob);\n      ctx.scale(-1, 1);\n      ctx.drawImage(img, sx, sy, sw, sh, -dw / 2, 0, dw, dh);\n    } else {\n      ctx.drawImage(img, sx, sy, sw, sh, dx + shake, dy + bob, dw, dh);\n    }\n    ctx.restore();\n\n    /* Accessory overlay */\n    if (p.acc && this.accImages[p.acc]) {\n      var accImg = this.accImages[p.acc];\n      /* Accessories are single-row strips; use same col for frame sync */\n      var accSy = 0;\n      ctx.save();\n      if (p.flipX) {\n        ctx.translate(p.x + shake, dy + bob);\n        ctx.scale(-1, 1);\n        ctx.drawImage(accImg, sx, accSy, sw, sh, -dw / 2, 0, dw, dh);\n      } else {\n        ctx.drawImage(accImg, sx, accSy, sw, sh, dx + shake, dy + bob, dw, dh);\n      }\n      ctx.restore();\n    }\n  }\n};\n",
