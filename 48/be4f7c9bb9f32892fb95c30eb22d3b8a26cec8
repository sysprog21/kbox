          "input": {
            "content": "#!/usr/bin/env python3\n\"\"\"Generate pixel-art penguin sprite sheets for kbox kernel house visualization.\n\nStyle: inspired by star-office-ui-v2's minimalist pixel aesthetic.\nCharacters are compact (14x14 body in 20x20 frame), high contrast,\nwith large expressive eyes relative to body size.\n\nOutputs:\n  web/art/penguin-base.png    -- 7x3 sprite sheet (140x60), resident Tux\n  web/art/penguin-guest.png   -- 7x3 sprite sheet, guest variant (teal)\n  web/art/acc-hat.png         -- 7x1 accessory strip (140x20)\n  web/art/acc-folder.png      -- 7x1 accessory strip\n  web/art/acc-stopwatch.png   -- 7x1 accessory strip\n  web/art/acc-memblock.png    -- 7x1 accessory strip\n  web/art/acc-envelope.png    -- 7x1 accessory strip\n\nFrame layout (7 cols): idle, walk1, walk2, walk3, type1, type2, error\nRow layout (3 rows):   down (front), up (back), left/right (side)\nEach frame: 20x20 pixels.\n\"\"\"\n\nimport struct\nimport zlib\nimport os\n\nFRAME_W, FRAME_H = 20, 20\nCOLS, ROWS = 7, 3\nSHEET_W, SHEET_H = FRAME_W * COLS, FRAME_H * ROWS\n\nCLEAR = (0, 0, 0, 0)\n\n# --- Tux color palette: high contrast, warm ---\nBODY = (30, 30, 45, 255)          # deep blue-black\nBELLY = (235, 235, 245, 255)      # bright white\nBEAK = (255, 180, 50, 255)        # warm gold-orange\nFEET = (255, 160, 30, 255)        # orange\nEYE_W = (255, 255, 255, 255)      # eye white\nPUPIL = (15, 15, 25, 255)         # near-black pupil\nCHEEK = (255, 140, 140, 255)      # rosy cheek highlight\n\n# Guest variant: teal/cyan tones\nG_BODY = (40, 80, 110, 255)\nG_BELLY = (180, 220, 240, 255)\n\n# Accessory colors (brighter, star-office-inspired)\nHAT_RED = (233, 69, 96, 255)     # hot pink accent (from star-office)\nHAT_GOLD = (255, 215, 0, 255)    # gold\nFOLDER_YEL = (255, 200, 60, 255)\nFOLDER_TAB = (230, 170, 40, 255)\nWATCH_SIL = (180, 185, 200, 255)\nWATCH_FACE = (240, 240, 255, 255)\nMEM_GREEN = (80, 200, 120, 255)\nMEM_CHIP = (50, 160, 90, 255)\nENV_CREAM = (255, 240, 210, 255)\nENV_SEAL = (233, 69, 96, 255)\n\n\ndef make_png(width, height, pixels):\n    \"\"\"Create a minimal PNG from RGBA pixel data.\"\"\"\n    def chunk(ctype, data):\n        c = ctype + data\n        crc = struct.pack('>I', zlib.crc32(c) & 0xFFFFFFFF)\n        return struct.pack('>I', len(data)) + c + crc\n\n    raw = b''\n    for y in range(height):\n        raw += b'\\x00'\n        for x in range(width):\n            r, g, b, a = pixels[y * width + x]\n            raw += struct.pack('BBBB', r, g, b, a)\n\n    sig = b'\\x89PNG\\r\\n\\x1a\\n'\n    ihdr = struct.pack('>IIBBBBB', width, height, 8, 6, 0, 0, 0)\n    return (sig + chunk(b'IHDR', ihdr) +\n            chunk(b'IDAT', zlib.compress(raw, 9)) +\n            chunk(b'IEND', b''))\n\n\ndef new_pixels(w, h):\n    return [CLEAR] * (w * h)\n\n\ndef put(px, w, x, y, c):\n    h = len(px) // w\n    if 0 <= x < w and 0 <= y < h:\n        px[y * w + x] = c\n\n\ndef rect(px, w, x0, y0, rw, rh, c):\n    for dy in range(rh):\n        for dx in range(rw):\n            put(px, w, x0 + dx, y0 + dy, c)\n\n\ndef draw_tux(px, w, fx, fy, facing, anim, body_c, belly_c):\n    \"\"\"Draw a compact, cute Tux. Body is roughly 10x10 centered in 20x20 frame.\n\n    facing: 0=front, 1=back, 2=side-left\n    anim: 0=idle, 1-3=walk, 4=type1, 5=type2(blink), 6=error\n    \"\"\"\n    ox = fx * FRAME_W\n    oy = fy * FRAME_H\n\n    # Walk bob: gentle sinusoidal feel via discrete offsets\n    bob = 0\n    if anim in (1, 3):\n        bob = -1\n    elif anim == 2:\n        bob = 0  # down frame of bounce\n\n    # Error horizontal jitter\n    jit = 1 if anim == 6 else 0\n\n    # Anchor: center of frame, penguin bottom at y=17\n    cx = ox + 10 + jit\n    by = oy + 17 + bob  # bottom of body\n\n    if facing == 0:  # front\n        # Body: rounded rectangle 10w x 9h\n        rect(px, w, cx - 5, by - 9, 10, 9, body_c)\n        # Round top corners\n        put(px, w, cx - 5, by - 9, CLEAR)\n        put(px, w, cx + 4, by - 9, CLEAR)\n        # Head: 10w x 6h sitting on body\n        rect(px, w, cx - 5, by - 14, 10, 5, body_c)\n        # Round head top\n        put(px, w, cx - 5, by - 14, CLEAR)\n        put(px, w, cx + 4, by - 14, CLEAR)\n        put(px, w, cx - 5, by - 13, CLEAR)\n        put(px, w, cx + 4, by - 13, CLEAR)\n        # Belly oval: 6w x 6h\n        rect(px, w, cx - 3, by - 7, 6, 6, belly_c)\n        # Eyes: 2x2 with 1x1 pupil\n        rect(px, w, cx - 4, by - 13, 2, 2, EYE_W)\n        rect(px, w, cx + 2, by - 13, 2, 2, EYE_W)\n        put(px, w, cx - 3, by - 12, PUPIL)\n        put(px, w, cx + 3, by - 12, PUPIL)\n        # Blink: close eyes on type2\n        if anim == 5:\n            rect(px, w, cx - 4, by - 13, 2, 2, body_c)\n            rect(px, w, cx + 2, by - 13, 2, 2, body_c)\n            rect(px, w, cx - 4, by - 12, 2, 1, EYE_W)  # thin line\n            rect(px, w, cx + 2, by - 12, 2, 1, EYE_W)\n        # Beak\n        rect(px, w, cx - 1, by - 10, 2, 1, BEAK)\n        # Cheek highlights\n        put(px, w, cx - 4, by - 11, CHEEK)\n        put(px, w, cx + 3, by - 11, CHEEK)\n        # Wings\n        rect(px, w, cx - 6, by - 8, 1, 5, body_c)\n        rect(px, w, cx + 5, by - 8, 1, 5, body_c)\n        # Wing flap on walk\n        if anim in (1, 3):\n            put(px, w, cx - 7, by - 7, body_c)\n            put(px, w, cx + 6, by - 7, body_c)\n        # Type pose: wing extended\n        if anim in (4, 5):\n            rect(px, w, cx + 5, by - 6, 2, 2, body_c)\n        # Feet\n        fy2 = by\n        if anim == 1:\n            rect(px, w, cx - 3, fy2, 2, 1, FEET)\n            rect(px, w, cx + 1, fy2 + 1, 2, 1, FEET)\n        elif anim == 3:\n            rect(px, w, cx - 3, fy2 + 1, 2, 1, FEET)\n            rect(px, w, cx + 1, fy2, 2, 1, FEET)\n        else:\n            rect(px, w, cx - 3, fy2, 2, 1, FEET)\n            rect(px, w, cx + 1, fy2, 2, 1, FEET)\n\n    elif facing == 1:  # back\n        rect(px, w, cx - 5, by - 14, 10, 14, body_c)\n        # Round corners\n        put(px, w, cx - 5, by - 14, CLEAR)\n        put(px, w, cx + 4, by - 14, CLEAR)\n        put(px, w, cx - 5, by - 13, CLEAR)\n        put(px, w, cx + 4, by - 13, CLEAR)\n        # Tail nub\n        put(px, w, cx, by - 1, body_c)\n        # Wings\n        rect(px, w, cx - 6, by - 8, 1, 5, body_c)\n        rect(px, w, cx + 5, by - 8, 1, 5, body_c)\n        if anim in (1, 3):\n            put(px, w, cx - 7, by - 7, body_c)\n            put(px, w, cx + 6, by - 7, body_c)\n        # Feet\n        rect(px, w, cx - 3, by, 2, 1, FEET)\n        rect(px, w, cx + 1, by, 2, 1, FEET)\n\n    elif facing == 2:  # side (facing left)\n        # Body 8w x 14h\n        rect(px, w, cx - 3, by - 14, 8, 14, body_c)\n        # Round top\n        put(px, w, cx - 3, by - 14, CLEAR)\n        put(px, w, cx + 4, by - 14, CLEAR)\n        put(px, w, cx - 3, by - 13, CLEAR)\n        # Belly side view\n        rect(px, w, cx - 3, by - 7, 4, 6, belly_c)\n        # Eye: one visible\n        rect(px, w, cx - 3, by - 13, 2, 2, EYE_W)\n        put(px, w, cx - 3, by - 12, PUPIL)\n        if anim == 5:\n            rect(px, w, cx - 3, by - 13, 2, 2, body_c)\n            rect(px, w, cx - 3, by - 12, 2, 1, EYE_W)\n        # Beak (pointing left)\n        rect(px, w, cx - 5, by - 11, 2, 1, BEAK)\n        # Cheek\n        put(px, w, cx - 2, by - 11, CHEEK)\n        # Wing (far side)\n        rect(px, w, cx + 4, by - 8, 1, 5, body_c)\n        if anim in (4, 5):\n            rect(px, w, cx - 5, by - 6, 2, 2, body_c)\n        # Feet\n        if anim == 1:\n            rect(px, w, cx - 2, by, 2, 1, FEET)\n            rect(px, w, cx + 1, by + 1, 2, 1, FEET)\n        elif anim == 3:\n            rect(px, w, cx - 2, by + 1, 2, 1, FEET)\n            rect(px, w, cx + 1, by, 2, 1, FEET)\n        else:\n            rect(px, w, cx - 1, by, 2, 1, FEET)\n            rect(px, w, cx + 2, by, 2, 1, FEET)\n\n\n# --- Accessories (drawn relative to frame, overlaid on character) ---\n\ndef draw_acc_hat(px, w, fx, fy):\n    ox, oy = fx * FRAME_W + 10, fy * FRAME_H + 2\n    # Pointed hat\n    rect(px, w, ox - 3, oy + 2, 6, 2, HAT_RED)\n    rect(px, w, ox - 2, oy + 1, 4, 1, HAT_RED)\n    rect(px, w, ox - 1, oy, 2, 1, HAT_RED)\n    rect(px, w, ox - 4, oy + 3, 8, 1, HAT_GOLD)  # gold band\n\ndef draw_acc_folder(px, w, fx, fy):\n    ox, oy = fx * FRAME_W + 14, fy * FRAME_H + 10\n    rect(px, w, ox, oy, 4, 5, FOLDER_YEL)\n    rect(px, w, ox, oy, 2, 1, FOLDER_TAB)\n\ndef draw_acc_stopwatch(px, w, fx, fy):\n    ox, oy = fx * FRAME_W + 14, fy * FRAME_H + 9\n    rect(px, w, ox, oy, 3, 3, WATCH_SIL)\n    put(px, w, ox + 1, oy + 1, WATCH_FACE)\n    put(px, w, ox + 1, oy - 1, WATCH_SIL)\n\ndef draw_acc_memblock(px, w, fx, fy):\n    ox, oy = fx * FRAME_W + 14, fy * FRAME_H + 9\n    rect(px, w, ox, oy, 4, 4, MEM_GREEN)\n    rect(px, w, ox, oy, 4, 1, MEM_CHIP)\n    rect(px, w, ox + 1, oy + 2, 2, 1, MEM_CHIP)\n\ndef draw_acc_envelope(px, w, fx, fy):\n    ox, oy = fx * FRAME_W + 14, fy * FRAME_H + 10\n    rect(px, w, ox, oy, 5, 3, ENV_CREAM)\n    # Seal dot\n    put(px, w, ox + 2, oy + 1, ENV_SEAL)\n    # Edge\n    rect(px, w, ox, oy, 5, 1, ENV_SEAL)\n\n\ndef generate_sheet(body_c, belly_c):\n    px = new_pixels(SHEET_W, SHEET_H)\n    for row in range(ROWS):\n        for col in range(COLS):\n            draw_tux(px, SHEET_W, col, row, row, col, body_c, belly_c)\n    return px\n\n\ndef generate_acc_sheet(draw_fn):\n    w, h = FRAME_W * COLS, FRAME_H\n    px = new_pixels(w, h)\n    for col in range(COLS):\n        draw_fn(px, w, col, 0)\n    return px, w, h\n\n\ndef main():\n    script_dir = os.path.dirname(os.path.abspath(__file__))\n    art_dir = os.path.join(os.path.dirname(script_dir), 'web', 'art')\n    os.makedirs(art_dir, exist_ok=True)\n\n    with open(os.path.join(art_dir, 'penguin-base.png'), 'wb') as f:\n        f.write(make_png(SHEET_W, SHEET_H, generate_sheet(BODY, BELLY)))\n\n    with open(os.path.join(art_dir, 'penguin-guest.png'), 'wb') as f:\n        f.write(make_png(SHEET_W, SHEET_H, generate_sheet(G_BODY, G_BELLY)))\n\n    for name, fn in [('acc-hat.png', draw_acc_hat),\n                     ('acc-folder.png', draw_acc_folder),\n                     ('acc-stopwatch.png', draw_acc_stopwatch),\n                     ('acc-memblock.png', draw_acc_memblock),\n                     ('acc-envelope.png', draw_acc_envelope)]:\n        px, w, h = generate_acc_sheet(fn)\n        with open(os.path.join(art_dir, name), 'wb') as f:\n            f.write(make_png(w, h, px))\n\n    print('Generated sprites in', art_dir)\n\n\nif __name__ == '__main__':\n    main()\n",
